{
  "name": "open-lces",
  "version": "1.0.4",
  "description": "This application exposes web api to manage a local currency exchange system. This solution manages multiple currencies, users, accounts, vouchers and perform operations like top-off and transfer to/from accounts.",
  "main": "server.js",
  "type": "module",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "start": "node server --omit=dev",
    "dev": "node --watch --env-file=.env server",
    "test": "cross-env NODE_ENV=test mocha --timeout 10000 tests/*.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsomville/open-CES.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jsomville/open-CES/issues"
  },
  "homepage": "https://github.com/jsomville/open-CES#readme",
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vonage/messages": "^1.24.0",
    "@vonage/server-sdk": "^3.27.0",
    "argon2": "^0.44.0",
    "axios": "^1.16.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "redis": "^5.12.1",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "cross-env": "^10.1.0",
    "mocha": "^11.7.6",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  }
}
